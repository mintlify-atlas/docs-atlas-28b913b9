  "keyFeatures": [
    "Progressive Web App with offline support",
    "Pomodoro timer with study session tracking",
    "Spaced repetition review system",
    "Study cycle planning and scheduling",
    "Multi-device sync via Cloudflare Workers",
    "Google Drive backup integration",
    "Dashboard with performance analytics",
    "Habit tracking for study activities",
    "Exam syllabus (editais) management",
    "AI-powered topic relevance analysis",
    "NLP and fuzzy matching for exam board intelligence",
    "IndexedDB state persistence",
    "Customizable themes and settings"
  ],
  "publicApiSurface": [
    "state - Global application state object",
    "setState(newState) - Update application state",
    "scheduleSave() - Debounced state persistence",
    "initDB() - Initialize IndexedDB",
    "navigate(view) - Navigate between app views",
    "toggleTimer(eventId) - Start/pause study timer",
    "marcarEstudei(eventId) - Mark study session as completed",
    "getAllDisciplinas() - Get all disciplines from editais",
    "getPendingRevisoes() - Get pending review items",
    "calcRevisionDates(dataConclusao, feitas, adiamentos) - Calculate spaced repetition dates",
    "generatePlanejamento(draft) - Generate study plan from wizard input",
    "syncCicloToEventos() - Sync study cycle to calendar events",
    "findBestMatch(editalSubjectName, disciplinaId) - NLP match exam topic to relevance database",
    "calculateFinalRelevance(editalSubjectCtx) - Calculate topic priority score",
    "applyRankingToEdital(editalId) - Rank exam topics by relevance",
    "tokenize(text) - NLP tokenization with stopword removal",
    "fuzzySimiliarity(word1, word2) - Levenshtein distance similarity",
    "pushToCloudflare() - Sync state to Cloudflare Worker",
    "pullFromCloudflare() - Pull state from Cloudflare Worker",
    "syncWithDrive() - Sync with Google Drive",
    "renderCurrentView() - Render active view component"
  ]
}
